import matplotlib.pyplot as plt

data_input = input("enter your data points separated by spaces(eg.10 25 15 30):")

y_values=[int(x)for x in data_input.split()]
x_values=range(len(y_values))

plt.plot(x_values,y_values,marker='o',linestyle='-',color='b')
plt.title("user generated line graph")
plt.xlabel("entry number")
plt.xlabel("entry number")
plt.ylabel("value")
plt.grid(True)
plt.show()

